# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=kimi-k2.5:cloud
OLLAMA_TIMEOUT_S=300

# HexStrike MCP (stdio). MCP_ARGS must be valid JSON array of strings.
MCP_COMMAND=python3
MCP_ARGS=["/Users/kumar.shashank/Desktop/hexstrike-ai/hexstrike_mcp.py","--server","http://127.0.0.1:8888"]

# Inherit full OS environment for the MCP subprocess (recommended on macOS/Linux)
MCP_INHERIT_FULL_ENV=true

# Comma-separated tool names from the MCP server, or * for all (large / risky)
TOOL_ALLOWLIST=*

# Optional: only names starting with this string (after allowlist)
TOOL_PREFIX=

MAX_TOOL_ROUNDS=15

# SYSTEM_PROMPT=You are a helpful assistant. Use tools when appropriate.
